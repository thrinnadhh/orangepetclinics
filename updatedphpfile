add_filter('query_vars', 'opc_services_query_vars', 0);
function opc_services_query_vars($vars) { $vars[] = 'my-services'; return $vars; }

add_filter('woocommerce_account_menu_items', 'opc_add_services_link_my_account');
function opc_add_services_link_my_account($items) {
    $new_items = array();
    foreach ($items as $key => $val) { $new_items[$key] = $val; if ($key === 'orders') $new_items['my-services'] = 'My Services'; }
    if (!isset($new_items['my-services'])) $new_items['my-services'] = 'My Services';
    return $new_items;
}

add_action('woocommerce_account_my-services_endpoint', 'opc_services_endpoint_content');
function opc_services_endpoint_content() {
    $current_user = wp_get_current_user();
    if (!$current_user->exists()) return;

    // Process Customer Cancellation
    if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['customer_cancel_id'])) {
        $cancel_id = sanitize_text_field($_POST['customer_cancel_id']);
        $history = get_option('opc_booking_history', array());
        $legacy  = get_option('opc_all_bookings', array());
        $changed = false;
        $process_cancellation = function(&$arr, $key, $b) use (&$changed) {
            $arr[$key]['status'] = 'cancelled'; $changed = true;
            $type = $b['type'] ?? 'grooming'; $date = $b['date'] ?? ''; $time = $b['time'] ?? '';
            if ($date && $time) {
                $opt = ($type === 'doctor') ? 'opc_booked_slots_doctor' : 'opc_booked_slots_grooming';
                $slots = get_option($opt, array());
                if (isset($slots[$date])) { $slots[$date] = array_values(array_diff($slots[$date], [$time])); update_option($opt, $slots); }
            }
        };
        foreach ($history as $key => $h) { if (($h['id']??'') === $cancel_id && !in_array($h['status']??'', ['cancelled','completed'])) $process_cancellation($history, $key, $h); }
        foreach ($legacy as $phone => $b) { if (($b['id']??'') === $cancel_id && !in_array($b['status']??'', ['cancelled','completed'])) $process_cancellation($legacy, $phone, $b); }
        if ($changed) { update_option('opc_booking_history', $history); update_option('opc_all_bookings', $legacy); echo '<div class="woocommerce-message" role="alert">Your appointment has been successfully cancelled.</div>'; }
    }

    $user_email = $current_user->user_email;
    $wc_phone   = preg_replace('/[^0-9]/', '', get_user_meta($current_user->ID, 'billing_phone', true));
    $history    = get_option('opc_booking_history', array());
    $legacy     = get_option('opc_all_bookings', array());
    $all_user_records = array();
    $six_months_ago = strtotime('-6 months');

    $check_booking = function($b) use ($user_email, $wc_phone, $six_months_ago, &$all_user_records) {
        $b_email = strtolower(trim($b['email'] ?? ''));
        $b_phone = preg_replace('/[^0-9]/', '', $b['phone'] ?? '');
        $b_date  = strtotime($b['date'] ?? '');
        $match   = (!empty($user_email) && $b_email === strtolower($user_email)) || (!empty($wc_phone) && $b_phone === $wc_phone);
        if ($match && $b_date >= $six_months_ago) { $all_user_records[$b['id'] ?? uniqid()] = $b; }
    };
    if (is_array($history)) foreach ($history as $b) $check_booking($b);
    if (is_array($legacy))  foreach ($legacy as $b)  $check_booking($b);

    $user_bookings = array_values($all_user_records);
    usort($user_bookings, function($a, $b) { return strtotime($b['date']) - strtotime($a['date']); });

    echo '<h3 style="margin-bottom:15px;color:#ea580c;display:flex;align-items:center;"><span class="dashicons dashicons-pets" style="margin-right:8px;line-height:unset;"></span> My Service Appointments (Last 6 Months)</h3>';

    if (empty($user_bookings)) {
        echo '<div class="woocommerce-info">You have not booked any services with us in the last 6 months.</div>';
    } else {
        echo '<table class="woocommerce-orders-table woocommerce-MyAccount-orders shop_table shop_table_responsive my_account_orders account-orders-table">';
        echo '<thead><tr><th>Service Type</th><th>Details</th><th>Date & Time</th><th>Status</th></tr></thead><tbody>';
        foreach ($user_bookings as $booking) {
            echo '<tr class="woocommerce-orders-table__row">';
            echo '<td data-title="Service Type">' . (isset($booking['type']) && $booking['type']==='doctor' ? '<span style="display:inline-block;background:#e0f2fe;color:#0369a1;padding:3px 8px;border-radius:4px;font-size:12px;font-weight:bold;">Doctor</span>' : '<span style="display:inline-block;background:#fce7f3;color:#be185d;padding:3px 8px;border-radius:4px;font-size:12px;font-weight:bold;">Grooming</span>') . '</td>';
            echo '<td data-title="Details">';
            if (isset($booking['type']) && $booking['type']==='doctor') { echo '<strong>' . esc_html($booking['doctor']??'Consultation') . '</strong>'; }
            else { echo '<strong>' . esc_html($booking['category']??'Grooming') . '</strong><br><small style="color:#666;">Size: ' . esc_html($booking['breed']??'') . '</small>'; }
            echo '</td>';
            echo '<td data-title="Date & Time"><strong>' . date_i18n(get_option('date_format'), strtotime($booking['date'])) . '</strong><br><span style="color:#ea580c;">' . esc_html($booking['time']) . '</span></td>';
            $status = $booking['status'] ?? 'active';
            $badges = ['rescheduled'=>['#fff3cd','#856404','Rescheduled'],'completed'=>['#e0e7ff','#3730a3','Completed'],'cancelled'=>['#fef2f2','#991b1b','Cancelled']];
            echo '<td data-title="Status">';
            if (isset($badges[$status])) { [$bg,$color,$label] = $badges[$status]; echo "<mark style=\"display:inline-block;padding:3px 8px;border-radius:4px;font-size:12px;background:{$bg};color:{$color};margin-bottom:5px;\"><span>{$label}</span></mark>"; }
            else { echo '<mark style="display:inline-block;padding:3px 8px;border-radius:4px;font-size:12px;background:#d1fae5;color:#065f46;margin-bottom:5px;"><span>Active</span></mark>'; }
            if (in_array($status, ['active','rescheduled']) && strtotime($booking['date']) >= strtotime('today')) {
                echo '<form method="POST" style="margin-top:10px;" onsubmit="return confirm(\'Are you sure you want to cancel? This cannot be undone.\');">';
                echo '<input type="hidden" name="customer_cancel_id" value="' . esc_attr($booking['id']??'') . '">';
                echo '<button type="submit" class="button" style="padding:4px 8px;font-size:11px;color:#dc2626;border-color:#fca5a5;background:white;">Cancel Service</button>';
                echo '</form>';
            }
            echo '</td></tr>';
        }
        echo '</tbody></table>';
    }
}

