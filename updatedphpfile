// 7. Ajax: Handle New Booking
add_action('wp_ajax_pet_booking', 'opc_v5_handle_booking');
add_action('wp_ajax_nopriv_pet_booking', 'opc_v5_handle_booking');
function opc_v5_handle_booking() {
    $raw_data = file_get_contents("php://input");
    $data = json_decode($raw_data, true);

    if (!$data) {
        wp_send_json_error("Invalid data received.");
    }

    $name = sanitize_text_field($data['name']);
    $email = sanitize_email($data['email']);
    $phone = sanitize_text_field($data['phone']);
    $type = sanitize_text_field($data['type'] ?? 'grooming'); // doctor or grooming
    $date = sanitize_text_field($data['date']);
    $time = sanitize_text_field($data['time']);

    $amount = floatval($data['amount']);

    if (empty($name) || empty($phone) || empty($date) || empty($time)) {
        wp_send_json_error("Missing required fields.");
    }

    // Determine lock key based on type
    $booked_option_key = ($type === 'doctor') ? 'opc_booked_slots_doctor' : 'opc_booked_slots_grooming';
    $slots = get_option($booked_option_key, array());

    if (!isset($slots[$date])) {
        $slots[$date] = array();
    }

    if (in_array($time, $slots[$date])) {
        wp_send_json_error("Slot already booked. Please refresh and try again.");
    }

    // Lock the slot
    $slots[$date][] = $time;
    update_option($booked_option_key, $slots);

    // Save Booking Data (Legacy format + new History format)
    $booking_id = uniqid('bkg_');
    $b_data = array(
        'id' => $booking_id,
        'name' => $name,
        'email' => $email,
        'phone' => $phone,
        'type' => $type,
        'date' => $date,
        'time' => $time,
        'amount' => $amount,
        'status' => 'active',
        'timestamp' => current_time('mysql')
    );

    if ($type === 'doctor') {
        $b_data['doctor'] = sanitize_text_field($data['doctor']);
    } else {
        $b_data['category'] = sanitize_text_field($data['category']);
        $b_data['breed'] = sanitize_text_field($data['breed']);
    }

    // A) LEGACY: Overwrite active booking per phone
    $bookings = get_option('opc_all_bookings', array());
    $bookings[$phone] = $b_data;
    update_option('opc_all_bookings', $bookings);

    // B) NEW HISTORY: Append to complete log
    $history = get_option('opc_booking_history', array());
    $history[] = $b_data;
    update_option('opc_booking_history', $history);

    wp_send_json_success("Booking Saved");
}

