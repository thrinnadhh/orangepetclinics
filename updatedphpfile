    <script>
        document.querySelector('input[name="block_all_day"]').addEventListener('change', function () { document.getElementById('timepicker').style.opacity = this.checked ? '0.5' : '1'; });
        document.querySelector('input[name="unblock_all_day"]').addEventListener('change', function () { document.getElementById('untimepicker').style.opacity = this.checked ? '0.5' : '1'; });

        // --- INVENTORY MANAGER SEARCH, HIGHLIGHT & PREVIEW ---
        document.addEventListener('DOMContentLoaded', function() {
            const invSearch = document.getElementById('inventorySearch');
            const invTable = document.getElementById('inventoryTable');
            const previewBtn = document.getElementById('previewChangesBtn');
            const previewModal = document.getElementById('previewModal');
            const previewContent = document.getElementById('previewContent');
            const confirmSaveBtn = document.getElementById('confirmSaveBtn');
            const bulkForm = document.getElementById('bulkInventoryForm');

            if(invSearch && invTable) {
                // 1. Live Search
                invSearch.addEventListener('input', function(e) {
                    const term = e.target.value.toLowerCase().trim();
                    const rows = invTable.querySelectorAll('.inv-row');
                    rows.forEach(row => {
                        const name = row.getAttribute('data-name');
                        if (name.includes(term)) {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    });
                });

                // 2. Highlight Changes & Show Main Save Button
                const inputs = invTable.querySelectorAll('.inv-field');
                inputs.forEach(input => {
                    input.addEventListener('input', function() {
                        const row = this.closest('tr');
                        const rowInputs = row.querySelectorAll('.inv-field');
                        let isChanged = false;
                        
                        rowInputs.forEach(inp => {
                            if(inp.value !== inp.getAttribute('data-orig')) {
                                isChanged = true;
                            }
                        });

                        if (isChanged) {
                            row.style.backgroundColor = '#fffbeb'; // Orange tint
                            row.style.boxShadow = 'inset 0 0 0 1px #fcd34d';
                            row.classList.add('is-modified');
                        } else {
                            row.style.backgroundColor = '';
                            row.style.boxShadow = '';
                            row.classList.remove('is-modified');
                        }

                        // Count total changes and show/hide preview button
                        const modifiedRowsCount = invTable.querySelectorAll('tr.is-modified').length;
                        document.getElementById('changeCount').innerText = modifiedRowsCount;
                        if (modifiedRowsCount > 0) {
                            previewBtn.style.display = 'block';
                        } else {
                            previewBtn.style.display = 'none';
                        }
                    });
                });

                // 3. Generate Preview Modal
                previewBtn.addEventListener('click', function() {
                    const modifiedRows = invTable.querySelectorAll('tr.is-modified');
                    let html = '<table style="width:100%; border-collapse:collapse; margin-bottom:10px;">';
                    html += '<tr style="background:#eee; text-align:left;"><th style="padding:10px; border-bottom:2px solid #ddd;">Product</th><th style="padding:10px; border-bottom:2px solid #ddd;">Change details</th></tr>';
                    
                    modifiedRows.forEach(row => {
                        const name = row.querySelector('a').innerText;
                        const priceInp = row.querySelector('.inv-price');
                        const stockInp = row.querySelector('.inv-stock');
                        
                        let changes = [];
                        
                        if (priceInp.value !== priceInp.getAttribute('data-orig')) {
                            changes.push(`Price: <strike style="color:#999;">₹${priceInp.getAttribute('data-orig')}</strike> &rarr; <strong style="color:#ea580c;">₹${priceInp.value}</strong>`);
                        }
                        if (stockInp.value !== stockInp.getAttribute('data-orig')) {
                            let oldStock = stockInp.getAttribute('data-orig') || 'N/A';
                            let newStock = stockInp.value || 'N/A';
                            changes.push(`Stock: <strike style="color:#999;">${oldStock}</strike> &rarr; <strong style="color:#16a34a;">${newStock}</strong>`);
                        }

                        html += `<tr>
                                    <td style="padding:12px 10px; border-bottom:1px solid #eee; width:45%;"><strong>${name}</strong></td>
                                    <td style="padding:12px 10px; border-bottom:1px solid #eee;">${changes.join('<br>')}</td>
                                 </tr>`;
                    });
                    
                    html += '</table>';
                    previewContent.innerHTML = html;
                    previewModal.style.display = 'flex';
                });

                // 4. Submit Changes via AJAX
                confirmSaveBtn.addEventListener('click', function() {
                    const modifiedRows = invTable.querySelectorAll('tr.is-modified');
                    let changesPayload = [];

                    modifiedRows.forEach(row => {
                        const id = row.getAttribute('data-id');
                        const price = row.querySelector('.inv-price').value;
                        const stock = row.querySelector('.inv-stock').value;
                        changesPayload.push({ id, price, stock });
                    });

                    confirmSaveBtn.innerText = 'Saving...';
                    confirmSaveBtn.disabled = true;

                    fetch(ajaxurl + '?action=update_wc_inventory_bulk', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ changes: changesPayload })
                    })
                    .then(res => res.json())
                    .then(res => {
                        if (res.success) {
                            alert(res.data.message);
                            location.reload(); 
                        } else {
                            alert("Error: " + res.data.message);
                            confirmSaveBtn.innerText = 'Confirm & Save All To Database';
                            confirmSaveBtn.disabled = false;
                        }
                    })
                    .catch(err => {
                        alert("An error occurred during save.");
                        confirmSaveBtn.innerText = 'Confirm & Save All To Database';
                        confirmSaveBtn.disabled = false;
                    });
                });
            }
        });
    </script>
    <?php
}

