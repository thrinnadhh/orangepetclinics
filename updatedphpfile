// 10. Ajax: Reschedule Booking
add_action('wp_ajax_reschedule_booking', 'opc_v5_reschedule');
add_action('wp_ajax_nopriv_reschedule_booking', 'opc_v5_reschedule');
function opc_v5_reschedule() {
    $raw_data = file_get_contents("php://input");
    $data = json_decode($raw_data, true);

    $phone = sanitize_text_field($data['phone']);
    $new_date = sanitize_text_field($data['new_date']);
    $new_time = sanitize_text_field($data['new_time']);

    if (!$phone || !$new_date || !$new_time) {
        echo wp_json_encode(['status' => 'error', 'data' => 'Missing data.']);
        exit;
    }

    $all_bookings = get_option('opc_all_bookings', array());

    if (!isset($all_bookings[$phone]) || ($all_bookings[$phone]['status'] ?? '') === 'completed' || ($all_bookings[$phone]['status'] ?? '') === 'cancelled') {
        echo wp_json_encode(['status' => 'error', 'data' => 'Booking not found or already completed/cancelled.']);
        exit;
    }

    $booking = $all_bookings[$phone];
    $old_date = $booking['date'];
    $old_time = $booking['time'];
    $type = $booking['type'] ?? 'grooming'; 

    $booked_option_key = ($type === 'doctor') ? 'opc_booked_slots_doctor' : 'opc_booked_slots_grooming';

    // Free old slot
    $slots = get_option($booked_option_key, array());
    if (isset($slots[$old_date])) {
        $slots[$old_date] = array_diff($slots[$old_date], [$old_time]);
        $slots[$old_date] = array_values($slots[$old_date]);
        update_option($booked_option_key, $slots);
    }

    // Lock new slot
    $slots = get_option($booked_option_key, array());
    if (!isset($slots[$new_date])) $slots[$new_date] = array();
    
    if (in_array($new_time, $slots[$new_date])) {
        echo wp_json_encode(['status' => 'error', 'data' => 'Timeslot already taken. Please refresh.']);
        exit;
    }

    $slots[$new_date][] = $new_time;
    update_option($booked_option_key, $slots);

    // Update the booking record (legacy)
    $all_bookings[$phone]['date'] = $new_date;
    $all_bookings[$phone]['time'] = $new_time;
    $all_bookings[$phone]['status'] = 'rescheduled'; 
    update_option('opc_all_bookings', $all_bookings);

    // Update in history log
    $history = get_option('opc_booking_history', array());
    foreach ($history as $key => $h) {
        if (($h['phone'] ?? '') === $phone && ($h['status'] ?? '') !== 'rescheduled' && ($h['status'] ?? '') !== 'completed' && ($h['status'] ?? '') !== 'cancelled') {
            $history[$key]['status'] = 'rescheduled';
            $history[$key]['date'] = $new_date;
            $history[$key]['time'] = $new_time;
        }
    }
    update_option('opc_booking_history', $history);

    echo wp_json_encode(['status' => 'success', 'data' => 'Rescheduled successfully.']);
    exit;
}

// 11. Ajax: Update WooCommerce Inventory (Bulk Save)
add_action('wp_ajax_update_wc_inventory_bulk', 'opc_v5_update_wc_inventory_bulk');
function opc_v5_update_wc_inventory_bulk() {
    if (!current_user_can('manage_options')) {
        wp_send_json_error(array('message' => 'Unauthorized'));
    }

    $raw_data = file_get_contents("php://input");
    $data = json_decode($raw_data, true);

    if (empty($data['changes']) || !is_array($data['changes'])) {
        wp_send_json_error(array('message' => 'No changes received.'));
        return;
    }

    $updated_count = 0;

    foreach ($data['changes'] as $change) {
        $product_id = intval($change['id']);
        $product = wc_get_product($product_id);
    
        if ($product) {
            if (isset($change['price'])) {
                $product->set_regular_price(sanitize_text_field($change['price']));
            }
            if (isset($change['stock'])) {
                $stock_val = sanitize_text_field($change['stock']);
                if ($stock_val === '' || $stock_val === null) {
                    $product->set_manage_stock(false);
                    $product->set_stock_status('instock');
                } else {
                    $product->set_manage_stock(true);
                    $product->set_stock_quantity(intval($stock_val));
                    $product->set_stock_status(intval($stock_val) > 0 ? 'instock' : 'outofstock');
                }
            }
            $product->save();
            $updated_count++;
        }
    }

    wp_send_json_success(array('message' => "Successfully updated $updated_count products!"));
}

// 12. Render Admin Dashboard
function opc_v5_render_admin_dashboard_safe() {
    global $wc_active;
    $message = '';

    // Handle Calendar Block
    if ($_POST && isset($_POST['opc_action']) && $_POST['opc_action'] === 'block_calendar') {
        $date = sanitize_text_field($_POST['block_date']);
        $type = sanitize_text_field($_POST['block_type']);
        $time = isset($_POST['block_time']) ? sanitize_text_field($_POST['block_time']) : '';
        $all_day = isset($_POST['block_all_day']) ? true : false;
        $times = array("10:00 AM", "11:00 AM", "12:00 PM", "1:00 PM", "2:00 PM", "3:00 PM", "4:00 PM", "5:00 PM", "6:00 PM", "7:00 PM", "8:00 PM");

        $slots_to_block = $all_day ? $times : array($time);
        
        $types_to_update = array();
        if ($type === 'both') {
            $types_to_update = array('opc_booked_slots_doctor', 'opc_booked_slots_grooming');
        } elseif ($type === 'doctor') {
            $types_to_update = array('opc_booked_slots_doctor');
        } else {
            $types_to_update = array('opc_booked_slots_grooming');
        }

        foreach ($types_to_update as $option_key) {
            $slots = get_option($option_key, array());
            if (!isset($slots[$date])) $slots[$date] = array();
            
            foreach ($slots_to_block as $t) {
                if (!in_array($t, $slots[$date])) {
                    $slots[$date][] = $t;
                }
            }
            update_option($option_key, $slots);
        }

        $message = '<div class="notice notice-success"><p>✅ Calendar successfully blocked!</p></div>';
    }

    // Handle Calendar Unblock
    if ($_POST && isset($_POST['opc_action']) && $_POST['opc_action'] === 'unblock_calendar') {
        $date = sanitize_text_field($_POST['unblock_date']);
        $type = sanitize_text_field($_POST['unblock_type']);
        $time = isset($_POST['unblock_time']) ? sanitize_text_field($_POST['unblock_time']) : '';
        $all_day = isset($_POST['unblock_all_day']) ? true : false;

        $types_to_update = array();
        if ($type === 'both') {
            $types_to_update = array('opc_booked_slots_doctor', 'opc_booked_slots_grooming');
        } elseif ($type === 'doctor') {
            $types_to_update = array('opc_booked_slots_doctor');
        } else {
            $types_to_update = array('opc_booked_slots_grooming');
        }

        foreach ($types_to_update as $option_key) {
            $slots = get_option($option_key, array());
            if (isset($slots[$date])) {
                if ($all_day) {
                    unset($slots[$date]);
                } else {
                    $slots[$date] = array_diff($slots[$date], array($time));
                    $slots[$date] = array_values($slots[$date]);
                }
                update_option($option_key, $slots);
            }
        }
        $message = '<div class="notice notice-success"><p>✅ Calendar successfully freed up!</p></div>';
    }

    // Handle Admin Complete
    if ($_POST && isset($_POST['opc_action']) && $_POST['opc_action'] === 'admin_complete') {
        $phone = sanitize_text_field($_POST['complete_phone'] ?? '');

        if (!empty($phone)) {
            $all_bookings = get_option('opc_all_bookings', array());
            if (isset($all_bookings[$phone])) {
                $all_bookings[$phone]['status'] = 'completed'; 
                update_option('opc_all_bookings', $all_bookings);

                // Update in history as well
                $history = get_option('opc_booking_history', array());
                foreach ($history as $key => $h) {
                    if (($h['phone'] ?? '') === $phone && (($h['status'] ?? '') === 'active' || ($h['status'] ?? '') === 'rescheduled')) {
                        $history[$key]['status'] = 'completed';
