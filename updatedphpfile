    return 'My Services';
}

// 3. Add the new tab to the My Account menu links
add_filter('woocommerce_account_menu_items', 'opc_add_services_link', 40);
function opc_add_services_link($menu_links) {
    // Insert after Orders (or just at the end)
    $new_links = array();
    foreach ($menu_links as $key => $val) {
        $new_links[$key] = $val;
        if ($key === 'orders') {
            $new_links['my-services'] = 'My Services';
        }
    }
    // Fallback if 'orders' doesn't exist
    if (!isset($new_links['my-services'])) {
        $new_links['my-services'] = 'My Services';
    }
    return $new_links;
}

// 4. Render content for the endpoint
add_action('woocommerce_account_my-services_endpoint', 'opc_services_endpoint_content');
function opc_services_endpoint_content() {
    $current_user = wp_get_current_user();
    if (!$current_user->exists()) return;

    // Process Customer Cancellation
    if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['customer_cancel_id'])) {
        $cancel_id = sanitize_text_field($_POST['customer_cancel_id']);
        $history = get_option('opc_booking_history', array());
        $legacy = get_option('opc_all_bookings', array());
        
        $changed = false;
        
        $process_cancellation = function(&$array_ref, $key, $b) use (&$changed) {
            $array_ref[$key]['status'] = 'cancelled';
            $changed = true;

            $type = $b['type'] ?? 'grooming';
            $date = $b['date'] ?? '';
            $time = $b['time'] ?? '';
            if ($date && $time) {
                $booked_option_key = ($type === 'doctor') ? 'opc_booked_slots_doctor' : 'opc_booked_slots_grooming';
                $slots = get_option($booked_option_key, array());
                if (isset($slots[$date])) {
                    $slots[$date] = array_diff($slots[$date], [$time]);
                    $slots[$date] = array_values($slots[$date]);
                    update_option($booked_option_key, $slots);
                }
            }
        };

        foreach ($history as $key => $h) {
            if (($h['id'] ?? '') === $cancel_id && ($h['status'] ?? '') !== 'cancelled' && ($h['status'] ?? '') !== 'completed') {
                $process_cancellation($history, $key, $h);
            }
        }
        foreach ($legacy as $phone => $b) {
            if (($b['id'] ?? '') === $cancel_id && ($b['status'] ?? '') !== 'cancelled' && ($b['status'] ?? '') !== 'completed') {
                $process_cancellation($legacy, $phone, $b);
            }
        }
        
        if ($changed) {
            update_option('opc_booking_history', $history);
            update_option('opc_all_bookings', $legacy);
            echo '<div class="woocommerce-message" role="alert">Your appointment has been successfully cancelled.</div>';
        }
    }

    // Fetch user details to link their historical appointments
    $user_email = $current_user->user_email;
    $wc_phone = get_user_meta($current_user->ID, 'billing_phone', true);
    
    // We will look up bookings in opc_booking_history (the permanent log)
    $history = get_option('opc_booking_history', array());
    $my_bookings = array();

    // 6-month cutoff
    $six_months_ago = strtotime('-6 months');

    foreach ($history as $booking) {
        $booking_time = strtotime($booking['timestamp'] ?? $booking['date']);
        if ($booking_time > $six_months_ago) {
            // Match against user's WordPress email OR their WooCommerce billing phone number
            if (($booking['email'] === $user_email) || (!empty($wc_phone) && $booking['phone'] === $wc_phone)) {
                $my_bookings[] = $booking;
            }
        }
    }

    // Sort descending by date
    usort($my_bookings, function($a, $b) {
        return strtotime($b['date'] . ' ' . $b['time']) - strtotime($a['date'] . ' ' . $a['time']);
    });

    echo '<h2 style="margin-top:0;">My Services History</h2>';
    
    if (empty($my_bookings)) {
        echo '<div class="woocommerce-info">You have not booked any services yet.</div>';
    } else {
        echo '<p>Here is a list of your pet\'s appointments from the last 6 months.</p>';
        echo '<table class="woocommerce-orders-table woocommerce-MyAccount-orders shop_table shop_table_responsive my_account_orders account-orders-table">';
        echo '<thead><tr>';
        echo '<th class="woocommerce-orders-table__header"><span class="nobr">Service Type</span></th>';
        echo '<th class="woocommerce-orders-table__header"><span class="nobr">Details</span></th>';
        echo '<th class="woocommerce-orders-table__header"><span class="nobr">Date & Time</span></th>';
        echo '<th class="woocommerce-orders-table__header"><span class="nobr">Total</span></th>';
        echo '<th class="woocommerce-orders-table__header"><span class="nobr">Status</span></th>';
        echo '</tr></thead>';
        echo '<tbody>';

        foreach ($my_bookings as $booking) {
            echo '<tr class="woocommerce-orders-table__row">';
            
            // Service Type
            echo '<td class="woocommerce-orders-table__cell" data-title="Service Type">';
            if (($booking['type'] ?? '') === 'doctor') {
                echo '<span style="display:inline-block; padding:4px 8px; background:#e0f2fe; color:#0369a1; border-radius:4px; font-weight:600; font-size:13px;">Doctor Consult</span>';
            } else {
                echo '<span style="display:inline-block; padding:4px 8px; background:#fce7f3; color:#be185d; border-radius:4px; font-weight:600; font-size:13px;">Grooming</span>';
            }
            echo '</td>';

            // Details
            echo '<td class="woocommerce-orders-table__cell" data-title="Details">';
            if (($booking['type'] ?? '') === 'doctor') {
                echo '<strong>' . esc_html($booking['doctor'] ?? 'General') . '</strong>';
            } else {
                echo '<strong>' . esc_html($booking['category'] ?? 'General') . '</strong><br>';
                echo '<span style="font-size:0.9em; color:#666;">Size: ' . esc_html($booking['breed'] ?? 'Unknown') . '</span>';
            }
            echo '</td>';

            // Date & Time
            echo '<td class="woocommerce-orders-table__cell" data-title="Date & Time">';
            echo '<strong>' . date('M j, Y', strtotime($booking['date'])) . '</strong><br>';
            echo '<span style="color:#ea580c; font-weight:bold;">' . esc_html($booking['time']) . '</span>';
            echo '</td>';

            // Total
            echo '<td class="woocommerce-orders-table__cell" data-title="Total">';
            echo '<span class="woocommerce-Price-amount amount"><bdi><span class="woocommerce-Price-currencySymbol">₹</span>' . number_format_i18n($booking['amount'] ?? 0, 2) . '</bdi></span>';
            echo '</td>';

            // Status
            echo '<td class="woocommerce-orders-table__cell" data-title="Status">';
            $status = $booking['status'] ?? 'active';
            if ($status === 'rescheduled') {
                echo '<mark class="order-status status-on-hold" style="background:#fff3cd; color:#856404; padding:3px 8px; border-radius:4px; font-size:12px; margin-bottom:5px; display:inline-block;"><span>Rescheduled</span></mark>';
            } elseif ($status === 'completed') {
                echo '<mark class="order-status status-completed" style="background:#e0e7ff; color:#3730a3; padding:3px 8px; border-radius:4px; font-size:12px; margin-bottom:5px; display:inline-block;"><span>Completed</span></mark>';
            } elseif ($status === 'cancelled') {
                echo '<mark class="order-status status-cancelled" style="background:#fef2f2; color:#991b1b; padding:3px 8px; border-radius:4px; font-size:12px; margin-bottom:5px; display:inline-block;"><span>Cancelled</span></mark>';
            } else {
                echo '<mark class="order-status status-processing" style="background:#d1fae5; color:#065f46; padding:3px 8px; border-radius:4px; font-size:12px; margin-bottom:5px; display:inline-block;"><span>Active</span></mark>';
            }

            // Show Cancel button if active or rescheduled and datetime is in future (or today)
            if (($status === 'active' || $status === 'rescheduled') && strtotime($booking['date']) >= strtotime('today')) {
                echo '<form method="POST" style="margin-top:10px;" onsubmit="return confirm(\'Are you sure you want to cancel this appointment? This cannot be undone.\');">';
                echo '<input type="hidden" name="customer_cancel_id" value="' . esc_attr($booking['id'] ?? '') . '">';
                echo '<button type="submit" class="button" style="padding:4px 8px; font-size:11px; color:#dc2626; border-color:#fca5a5; background:white;">Cancel Service</button>';
                echo '</form>';
            }

            echo '</td>';

            echo '</tr>';
        }
        echo '</tbody></table>';
    }
}
